# Paperclip - Machine.Machine deployment config
# Copy to .env and fill in secrets

# Database (use external postgres in prod)
DATABASE_URL=postgres://paperclip:paperclip@db:5432/paperclip

# Server
PORT=3100
HOST=0.0.0.0
SERVE_UI=true
NODE_ENV=production

# Auth (REQUIRED - generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Public URL (set to your actual domain)
PAPERCLIP_PUBLIC_URL=http://paperclip.machinemachine.ai

# Deployment mode
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
